{{ config(materialized='table') }}

with source as (
    select distinct reserved_room_type as room_type_code
    from {{ ref('stg_bookings') }}
    where reserved_room_type is not null
),

final as (
    select
        ROW_NUMBER() OVER (ORDER BY room_type_code)     as reserved_room_key,
        room_type_code
    from source
)

select * from final
