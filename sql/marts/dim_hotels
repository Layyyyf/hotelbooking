{{ config(materialized='table') }}

with source as (
    select distinct hotel from {{ ref('stg_bookings') }}
),

final as (
    select
        ROW_NUMBER() OVER (ORDER BY hotel)      as hotel_key,
        hotel                                   as hotel_name,
        CASE
            WHEN hotel = 'City Hotel'   THEN 'City'
            WHEN hotel = 'Resort Hotel' THEN 'Resort'
        END                                     as hotel_type
    from source
)

select * from final
