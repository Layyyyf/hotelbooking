with source as (
    select * from {{ source('hotelbooking_dbo', 'bookings') }}
),

renamed as (
    select
        -- hotel identifier
        LTRIM(RTRIM(hotel))                                                     as hotel,
        CAST(is_canceled AS BIT)                                                as is_canceled,

        -- lead time
        lead_time,

        -- arrival date components (kept for reference)
        arrival_date_year,
        LTRIM(RTRIM(arrival_date_month))                                        as arrival_date_month,
        arrival_date_week_number,
        arrival_date_day_of_month,

        -- arrival date rebuilt as a proper date
        DATEFROMPARTS(
            arrival_date_year,
            DATEPART(MONTH, CAST(LTRIM(RTRIM(arrival_date_month)) + ' 01 2000' AS DATE)),
            arrival_date_day_of_month
        )                                                                       as arrival_date,

        -- stay duration
        stays_in_weekend_nights,
        stays_in_week_nights,
        stays_in_weekend_nights + stays_in_week_nights                          as total_nights,

        -- guest composition
        COALESCE(adults, 0)                                                     as adults,
        COALESCE(children, 0)                                                   as children,
        COALESCE(babies, 0)                                                     as babies,
        COALESCE(adults, 0) + COALESCE(children, 0) + COALESCE(babies, 0)      as total_guests,

        -- booking attributes
        -- 'Undefined' sentinel → NULL (meal: 1,169 rows; market_segment: 2; distribution_channel: 5)
        NULLIF(LTRIM(RTRIM(meal)), 'Undefined')                                 as meal,
        CASE LTRIM(RTRIM(meal))
            WHEN 'BB'        THEN 'Bed & Breakfast'
            WHEN 'HB'        THEN 'Half Board'
            WHEN 'FB'        THEN 'Full Board'
            WHEN 'SC'        THEN 'Self Catering'
            ELSE NULL
        END                                                                     as meal_name,
        NULLIF(LTRIM(RTRIM(country)), 'NULL')                                   as country,
        NULLIF(LTRIM(RTRIM(market_segment)), 'Undefined')                       as market_segment,
        NULLIF(LTRIM(RTRIM(distribution_channel)), 'Undefined')                 as distribution_channel,
        CAST(is_repeated_guest AS BIT)                                          as is_repeated_guest,
        previous_cancellations,
        previous_bookings_not_canceled,

        -- room assignment
        LTRIM(RTRIM(reserved_room_type))                                        as reserved_room_type,
        LTRIM(RTRIM(assigned_room_type))                                        as assigned_room_type,
        booking_changes,

        -- deposit and agent
        LTRIM(RTRIM(deposit_type))                                              as deposit_type,
        agent,
        NULLIF(LTRIM(RTRIM(company)), 'NULL')                                   as company,

        -- waiting list
        days_in_waiting_list,

        -- customer and pricing
        LTRIM(RTRIM(customer_type))                                             as customer_type,
        COALESCE(CAST(adr AS DECIMAL(10, 2)), 0.00)                             as adr,

        -- special needs
        required_car_parking_spaces,
        total_of_special_requests,

        -- reservation status
        LTRIM(RTRIM(reservation_status))                                        as reservation_status,
        reservation_status_date

    from source
),

